# Neon Database URL
DATABASE_URL="postgresql://<username>:<password>@<host>.neon.tech/<dbname>?sslmode=verify-full"

# Better Auth settings
BETTER_AUTH_SECRET="<your-secret-generated>"
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth
GITHUB_CLIENT_ID="<your-github-client-id>"
GITHUB_CLIENT_SECRET="<your-github-client-secret>"